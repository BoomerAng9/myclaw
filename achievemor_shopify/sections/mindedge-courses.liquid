{% style %}
  .mindedge-page {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      color: #1a1a1a;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 20px;
  }

  /* --- Dynamic Hero Section --- */
  .mindedge-hero {
      background: linear-gradient(145deg, #05050A 0%, #141419 100%);
      color: #ffffff;
      text-align: center;
      padding: 100px 20px;
      border-radius: 24px;
      margin-bottom: 60px;
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.05);
      box-shadow: 0 20px 40px rgba(0,0,0,0.5);
  }

  .mindedge-hero::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; height: 4px;
      background: linear-gradient(90deg, #6C5CE7, #00CECE);
  }

  .mindedge-hero-badge {
      display: inline-block;
      background: rgba(0, 206, 206, 0.1);
      color: #00CECE;
      padding: 8px 16px;
      border-radius: 9999px;
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 24px;
      border: 1px solid rgba(0, 206, 206, 0.3);
  }

  .mindedge-hero h1 {
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 800;
      margin-bottom: 24px;
      line-height: 1.1;
      letter-spacing: -1px;
  }
  
  .mindedge-hero h1 span {
      background: linear-gradient(135deg, #6C5CE7, #00CECE);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
  }

  .mindedge-hero p {
      font-size: 1.25rem;
      max-width: 800px;
      margin: 0 auto 40px auto;
      color: #A0A0B0;
      line-height: 1.6;
  }

  .mindedge-trust-bar {
      display: flex;
      justify-content: center;
      gap: 32px;
      flex-wrap: wrap;
      margin-top: 20px;
  }

  .trust-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.95rem;
      font-weight: 600;
      color: #FFF;
      background: rgba(255,255,255,0.05);
      padding: 12px 24px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.1);
  }

  .trust-item svg { width: 20px; height: 20px; fill: #00CECE; }

  /* --- Category Grid --- */
  .mindedge-section-title {
      text-align: center;
      font-size: 2.5rem;
      font-weight: 800;
      margin-bottom: 40px;
      color: #05050A;
      letter-spacing: -0.5px;
  }

  .mindedge-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 24px;
      margin-bottom: 100px;
  }

  .mindedge-cat-card {
      background: #ffffff;
      border-radius: 16px;
      padding: 32px 24px;
      text-align: center;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
      border: 1px solid #E2E8F0;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      display: flex;
      flex-direction: column;
      align-items: center;
      text-decoration: none !important;
      position: relative;
      overflow: hidden;
  }

  .mindedge-cat-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0; height: 4px;
      background: linear-gradient(90deg, #6C5CE7, #00CECE);
      transform: scaleX(0);
      transition: transform 0.3s ease;
      transform-origin: left;
  }

  .mindedge-cat-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
      border-color: #CBD5E1;
  }

  .mindedge-cat-card:hover::after {
      transform: scaleX(1);
  }

  .mindedge-cat-icon {
      width: 64px;
      height: 64px;
      border-radius: 16px;
      background: rgba(108, 92, 231, 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      margin-bottom: 20px;
      color: #6C5CE7;
  }

  .mindedge-cat-title {
      font-size: 1.5rem;
      font-weight: 800;
      color: #0F172A;
      margin-bottom: 12px;
  }

  .mindedge-cat-desc {
      font-size: 1rem;
      color: #64748B;
      line-height: 1.5;
      margin-bottom: 24px;
      flex-grow: 1;
  }

  .mindedge-cat-btn {
      display: inline-block;
      padding: 10px 24px;
      background: #F8FAFC;
      color: #0F172A;
      font-weight: 600;
      border-radius: 8px;
      border: 1px solid #E2E8F0;
      transition: all 0.2s;
  }

  .mindedge-cat-card:hover .mindedge-cat-btn {
      background: #0F172A;
      color: #FFFFFF;
      border-color: #0F172A;
  }

  /* Responsive */
  @media (max-width: 768px) {
      .mindedge-hero { padding: 60px 20px; }
      .mindedge-trust-bar { flex-direction: column; align-items: stretch; }
  }
{% endstyle %}

