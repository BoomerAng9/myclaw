+/* ═══════════════════════════════════════════════════════════════
+   Guide_Ang — MyClaw Native Chat Interface
+   Premium glassmorphic floating assistant
+   ═══════════════════════════════════════════════════════════════ */
+
+:root {
+  --guide-glass-bg: rgba(10, 10, 10, 0.85);
+  --guide-glass-border: rgba(255, 255, 255, 0.08);
+  --guide-accent: #0066ff;
+  --guide-accent-glow: rgba(0, 102, 255, 0.25);
+  --guide-text-primary: #ffffff;
+  --guide-text-secondary: rgba(255, 255, 255, 0.5);
+  --guide-bubble-size: 56px;
+  --guide-panel-width: 380px;
+  --guide-panel-height: 540px;
+}
+
+/* ── Floating Trigger Bubble ─────────────────────────────────── */
+.guide-bubble {
+  position: fixed;
+  bottom: 28px;
+  right: 28px;
+  width: var(--guide-bubble-size);
+  height: var(--guide-bubble-size);
+  background: var(--guide-accent);
+  border-radius: 50%;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  cursor: pointer;
+  box-shadow: 0 6px 24px var(--guide-accent-glow);
+  transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275),
+              box-shadow 0.3s ease;
+  z-index: 9999;
+}
+
+.guide-bubble:hover {
+  transform: scale(1.08) translateY(-3px);
+  box-shadow: 0 10px 36px var(--guide-accent-glow);
+}
+
+.guide-bubble.hidden { display: none; }
+
+.guide-bubble svg {
+  width: 26px;
+  height: 26px;
+  color: white;
+}
+
+/* ── Chat Panel ──────────────────────────────────────────────── */
+.guide-panel {
+  position: fixed;
+  bottom: 96px;
+  right: 28px;
+  width: var(--guide-panel-width);
+  height: var(--guide-panel-height);
+  background: var(--guide-glass-bg);
+  backdrop-filter: blur(24px);
+  -webkit-backdrop-filter: blur(24px);
+  border: 1px solid var(--guide-glass-border);
+  border-radius: 20px;
+  display: flex;
+  flex-direction: column;
+  overflow: hidden;
+  box-shadow: 0 16px 48px rgba(0, 0, 0, 0.45);
+  transform: translateY(16px) scale(0.96);
+  opacity: 0;
+  pointer-events: none;
+  transition: transform 0.35s cubic-bezier(0.19, 1, 0.22, 1),
+              opacity 0.35s ease;
+  z-index: 9998;
+}
+
+.guide-panel.active {
+  transform: translateY(0) scale(1);
+  opacity: 1;
+  pointer-events: all;
+}
+
+/* ── Panel Header ────────────────────────────────────────────── */
+.guide-header {
+  padding: 20px 22px;
+  border-bottom: 1px solid var(--guide-glass-border);
+  display: flex;
+  align-items: center;
+  gap: 14px;
+}
+
+.guide-header-icon {
+  width: 36px;
+  height: 36px;
+  background: var(--guide-accent);
+  border-radius: 10px;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  flex-shrink: 0;
+}
+
+.guide-header-status {
+  display: flex;
+  flex-direction: column;
+  gap: 2px;
+}
+
+.guide-header-title {
+  font-weight: 700;
+  font-size: 0.95rem;
+  color: var(--guide-text-primary);
+  letter-spacing: -0.01em;
+}
+
+.guide-header-tagline {
+  font-size: 0.72rem;
+  color: var(--guide-text-secondary);
+  letter-spacing: 0.02em;
+}
+
+/* ── Message Area ────────────────────────────────────────────── */
+.guide-messages {
+  flex: 1;
+  overflow-y: auto;
+  padding: 20px;
+  display: flex;
+  flex-direction: column;
+  gap: 12px;
+  scrollbar-width: thin;
+  scrollbar-color: rgba(255,255,255,0.08) transparent;
+}
+
+.guide-messages::-webkit-scrollbar { width: 4px; }
+.guide-messages::-webkit-scrollbar-track { background: transparent; }
+.guide-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 4px; }
+
+.guide-message {
+  max-width: 88%;
+  padding: 10px 14px;
+  border-radius: 14px;
+  font-size: 0.88rem;
+  line-height: 1.55;
+  animation: msgIn 0.25s ease forwards;
+}
+
+@keyframes msgIn {
+  from { opacity: 0; transform: translateY(8px); }
+  to   { opacity: 1; transform: translateY(0); }
+}
+
+.guide-message.bot {
+  align-self: flex-start;
+  background: rgba(255, 255, 255, 0.06);
+  color: var(--guide-text-primary);
+  border-bottom-left-radius: 4px;
+}
+
+.guide-message.user {
+  align-self: flex-end;
+  background: var(--guide-accent);
+  color: white;
+  border-bottom-right-radius: 4px;
+}
+
+/* ── Input Area ──────────────────────────────────────────────── */
+.guide-input-container {
+  padding: 16px 20px;
+  background: rgba(0, 0, 0, 0.25);
+  border-top: 1px solid var(--guide-glass-border);
+}
+
+.guide-input-wrapper {
+  background: rgba(255, 255, 255, 0.06);
+  border-radius: 14px;
+  padding: 6px 14px;
+  display: flex;
+  align-items: center;
+  gap: 10px;
+  border: 1px solid transparent;
+  transition: border-color 0.2s ease;
+}
+
+.guide-input-wrapper:focus-within {
+  border-color: var(--guide-accent);
+}
+
+.guide-input {
+  background: transparent;
+  border: none;
+  color: var(--guide-text-primary);
+  flex: 1;
+  padding: 8px 0;
+  outline: none;
+  font-size: 0.88rem;
+  font-family: 'Inter', sans-serif;
+}
+
+.guide-input::placeholder {
+  color: var(--guide-text-secondary);
+}
+
+.guide-send-btn {
+  background: none;
+  border: none;
+  color: var(--guide-accent);
+  cursor: pointer;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  padding: 4px;
+  transition: transform 0.15s ease, opacity 0.15s ease;
+}
+
+.guide-send-btn:hover {
+  transform: scale(1.12);
+}
+
+.guide-send-btn:disabled {
+  opacity: 0.3;
+  cursor: not-allowed;
+}
+
+/* ── Typing Indicator ────────────────────────────────────────── */
+.typing-indicator {
+  display: flex;
+  gap: 4px;
+  padding: 4px 0;
+}
+
+.typing-dot {
+  width: 5px;
+  height: 5px;
+  background: var(--guide-text-secondary);
+  border-radius: 50%;
+  animation: bounce 1s infinite ease-in-out;
+}
+
+.typing-dot:nth-child(2) { animation-delay: 0.15s; }
+.typing-dot:nth-child(3) { animation-delay: 0.3s; }
+
+@keyframes bounce {
+  0%, 80%, 100% { transform: translateY(0); }
+  40% { transform: translateY(-4px); }
+}
+
+
+
+/* ── Attachments (NotebookLM Data Sources) ───────────────────── */
+.attachment-msg {
+  background: rgba(255, 255, 255, 0.03);
+  border: 1px solid var(--guide-glass-border);
+  display: flex;
+  flex-direction: column;
+  gap: 8px;
+  max-width: 95%;
+}
+
+.attachment-label {
+  font-weight: 600;
+  font-size: 0.85rem;
+  color: #fff;
+  opacity: 0.9;
+}
+
+.guide-audio-player {
+  width: 100%;
+  height: 32px;
+  outline: none;
+  border-radius: 8px;
+  margin-top: 4px;
+}
+
+.attachment-doc {
+  display: inline-flex;
+  align-items: center;
+  gap: 6px;
+  color: var(--guide-accent);
+  text-decoration: none;
+  font-weight: 500;
+  background: rgba(0, 102, 255, 0.1);
+  padding: 8px 12px;
+  border-radius: 6px;
+  transition: background 0.2s ease;
+}
+
+.attachment-doc:hover {
+  background: rgba(0, 102, 255, 0.2);
+}
+
+/* ── NotebookLM Attachments ──────────────────────────────────── */
+.guide-attachment {
+  margin-top: 10px;
+  padding-top: 10px;
+  border-top: 1px solid rgba(255, 255, 255, 0.1);
+}
+
+.audio-player {
+  background: rgba(0, 0, 0, 0.4);
+  border: 1px solid var(--guide-glass-border);
+  border-radius: 8px;
+  padding: 10px;
+}
+
+.audio-label {
+  font-size: 13px;
+  color: var(--guide-accent);
+  margin-bottom: 8px;
+  font-weight: 500;
+}
+
+.custom-audio {
+  width: 100%;
+  height: 32px;
+  outline: none;
+}
+
+.doc-link {
+  display: inline-flex;
+  align-items: center;
+  gap: 8px;
+  padding: 8px 12px;
+  background: rgba(0, 0, 0, 0.4);
+  border: 1px solid var(--guide-glass-border);
+  border-radius: 6px;
+  color: var(--guide-accent);
+  text-decoration: none;
+  font-size: 13px;
+  transition: all 0.2s;
+}
+
+.doc-link:hover {
+  background: rgba(212, 160, 48, 0.1);
+  border-color: rgba(212, 160, 48, 0.3);
+}
+
+/* ── Responsive ──────────────────────────────────────────────── */
+@media (max-width: 480px) {
+  .guide-panel {
+    right: 12px;
+    bottom: 80px;
+    width: calc(100vw - 24px);
+    height: 70vh;
+  }
+  .guide-bubble {
+    right: 16px;
+    bottom: 16px;
+  }
+}
diff --git a/acheevy-deployment/acheevy-chat.js b/acheevy-deployment/acheevy-chat.js
