{
  "plugins": {
    "allow": [
      "telegram",
      "oxylabs-ai-studio-openclaw"
    ],
    "entries": {
      "telegram": {
        "enabled": false,
        "token": "CHANGE_ME"
      },
      "oxylabs-ai-studio-openclaw": {
        "enabled": true
      }
    }
  },
  "tools": {
    "web": {
      "search": {
        "enabled": false
      },
      "fetch": {
        "enabled": false
      }
    }
  },
  "browser": {
    "headless": true,
    "noSandbox": true,
    "defaultProfile": "openclaw"
  },
  "models": {
    "mode": "merge",
    "providers": {
      "nexos": {
        "baseUrl": "https://api.nexos.ai/v1",
        "api": "openai-completions",
        "auth": "api-key",
        "models": [
          {
            "id": "primary-model-id",
            "name": "Primary Model",
            "reasoning": true,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "maxTokens": 8192,
            "contextWindow": 200000,
            "compat": {
              "supportsStore": true,
              "supportsDeveloperRole": true,
              "supportsReasoningEffort": false
            }
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "Primary Model"
      },
      "models": {
        "nexos/primary-model-id": {}
      }
    }
  },
  "approvals": {
    "mode": "default"
  }
}