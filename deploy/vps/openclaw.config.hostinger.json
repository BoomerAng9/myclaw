    "enabled": true,
    "maxConcurrentRuns": 3,
    "sessionRetention": "7d",
    "jobs": [
      {
        "id": "daily-revenue-check",
        "name": "Daily MindEdge Revenue Summary",
        "schedule": "0 9 * * *",
        "timezone": "America/New_York",
        "agentId": "main",
        "session": "isolated",
        "message": "Check the MindEdge partner dashboard and Shopify admin. Summarize: today's revenue, active learners, new course completions, and any store alerts. Format as a brief daily report.",
        "enabled": true,
        "note": "Enable once Telegram channel is connected for delivery"
      },
      {
        "id": "weekly-catalog-sync",
        "name": "Weekly Shopify vs MindEdge Catalog Audit",
        "schedule": "0 10 * * 1",
        "timezone": "America/New_York",
        "agentId": "main",
        "session": "isolated",
        "message": "Compare the MindEdge catalog at catalog.mindedge.com/achievemor against the current Shopify product list. Report any new courses, removed courses, or price changes.",
        "enabled": true,
        "note": "Enable once Telegram channel is connected for delivery"
      }
    ]
  },
  "gateway": {
    "mode": "local",
