{
  "swarmId": "chicken-hawk-v1",
  "name": "Chicken Hawk Agent Swarm",
  "version": "1.0.0",
  "description": "Chicken Hawk (OpenClaw / NemoClaw / MyClaw) is the single deployed AI runtime. It spawns lil_hawks — narrow sub-agents — for parallel task execution. This registry defines the lil_hawks that Chicken Hawk can dispatch.",
  "master": {
    "id": "chicken-hawk",
    "aliases": ["openclaw", "nemoclaw", "myclaw"],
    "runtime": "ghcr.io/nvidia/openshell/cluster:0.0.10",
    "port": 8080,
    "role": "The deployed AI runtime. Everything runs through this single instance.",
    "capabilities": [
      "dynamic_skilling_mcp",
      "voice_first_vision_first_loop",
      "stt_tts_processing",
      "delta_screenshot_analysis",
      "make_it_mine_cloning",
      "coolify_auto_deploy",
      "luc_metering_enforcement",
      "kata_microvm_sandbox",
      "telegram_command_routing",
      "lil_hawks_spawning",
      "grammar_runtime_enforcement"
    ]
  },
  "orchestrator": "acheevy",
  "routingPolicy": "capability-first",
  "providerAgnostic": true,
  "lil_hawks": [
    {
      "id": "acheevy",
      "config": "../../../aims-tools/luc/agents/lil-hawk-acheevy.json",
      "role": "orchestrator",
      "canDelegate": true,
      "canExecute": false,
      "priority": 0,
      "description": "Digital CEO. Interprets user intent, sequences work, packages evidence bundles."
    },
    {
      "id": "picker",
      "config": "../../../aims-tools/luc/agents/lil-hawk-picker.json",
      "role": "router",
      "canDelegate": false,
      "canExecute": false,
      "priority": 1,
      "description": "Routes tasks to the right lil_hawk by capability class, not vendor."
    },
    {
      "id": "cfo",
      "config": "../../../aims-tools/luc/agents/lil-hawk-cfo.json",
      "role": "finance-gate",
      "canDelegate": false,
      "canExecute": false,
      "priority": 2,
      "description": "LUC quota gate. Blocks actions exceeding cost limits."
    },
    {
      "id": "coder",
      "config": "agents/coder-ang.json",
      "role": "code-producer",
      "canDelegate": false,
      "canExecute": true,
      "priority": 3
    },
    {
      "id": "validator",
      "config": "agents/validator-ang.json",
      "role": "review-gate",
      "canDelegate": false,
      "canExecute": false,
      "priority": 4,
      "description": "Security and quality review gate. Must pass before any delivery."
    },
    {
      "id": "researcher",
      "config": "agents/research-ang.json",
      "role": "intelligence",
      "canDelegate": false,
      "canExecute": false,
      "priority": 3
    },
    {
      "id": "ops",
      "config": "agents/ops-ang.json",
      "role": "notifications",
      "canDelegate": false,
      "canExecute": false,
      "priority": 5,
      "description": "Bulk outbound notifications (Slack, Discord, Telegram formatting)."
    },
    {
      "id": "designer",
      "config": "agents/designer-ang.json",
      "role": "visual-producer",
      "canDelegate": false,
      "canExecute": false,
      "priority": 3
    },
    {
      "id": "sme-stepper",
      "config": "agents/sme-stepper-ang.json",
      "role": "stepper-skill-manager",
      "canDelegate": false,
      "canExecute": false,
      "priority": 3
    },
    {
      "id": "sme-paperform",
      "config": "agents/sme-paperform-ang.json",
      "role": "paperform-skill-manager",
      "canDelegate": false,
      "canExecute": false,
      "priority": 3
    },
    {
      "id": "sme-notebooklm",
      "config": "agents/sme-notebooklm-ang.json",
      "role": "audio-intelligence-specialist",
      "canDelegate": false,
      "canExecute": true,
      "priority": 3,
      "description": "Generates podcasts, briefings, and FAQs via Gemini+TTS or NotebookLM."
    },
    {
      "id": "betty-anne",
      "config": "agents/betty-anne-ang.json",
      "role": "hr-oversight",
      "canDelegate": false,
      "canExecute": false,
      "priority": 1,
      "description": "PMO HR oversight. Grades lil_hawk performance against TEP objectives."
    },
    {
      "id": "scripter",
      "config": "agents/scripter-ang.json",
      "role": "narrative-producer",
      "canDelegate": false,
      "canExecute": true,
      "priority": 3,
      "description": "Drafts execution narratives and video pipeline scripts."
    },
    {
      "id": "avva-noon",
      "config": "agents/avva-noon.json",
      "role": "escalation-failover",
      "canDelegate": true,
      "canExecute": true,
      "priority": 0,
      "description": "Agent Zero. Last resort failover via OODA loop. Pages human on double failure."
    },
    {
      "id": "autoresearch",
      "config": "vendor/autoresearch",
      "role": "autonomous-research",
      "canDelegate": false,
      "canExecute": true,
      "priority": 3,
      "description": "Karpathy AutoResearch engine. Background data crunching on free OpenRouter models."
    }
  ],
  "executionRules": {
    "maxParallelAgents": 6,
    "timeoutMs": 120000,
    "retryPolicy": {
      "maxRetries": 2,
      "backoffMs": 3000
    },
    "approvalRequired": ["coder", "designer", "scripter"],
    "alwaysReview": true,
    "evidenceRequired": true,
    "escalationAgent": "avva-noon",
    "hrOversightAgent": "betty-anne"
  },
  "pipelineOrder": [
    "acheevy → interpret intent",
    "picker → route to capability class",
    "cfo → LUC quota gate check",
    "betty-anne → TEP performance gate (parallel)",
    "sme-stepper → validate external architecture (if applicable)",
    "sme-notebooklm → audio intelligence (if applicable)",
    "coder | researcher | designer | scripter | autoresearch → parallel execution",
    "validator → review gate",
    "avva-noon → escalation failover (on failure only)",
    "ops → deliver notifications",
    "acheevy → package evidence bundle"
  ],
  "skillLibrary": {
    "superpowers": "skills/using-superpowers/SKILL.md",
    "systematicDebugging": "skills/systematic-debugging/SKILL.md",
    "parallelAgents": "skills/dispatching-parallel-agents/SKILL.md",
    "tdd": "skills/test-driven-development/SKILL.md",
    "brainstorming": "skills/brainstorming/SKILL.md",
    "codeReview": "skills/requesting-code-review/SKILL.md",
    "writingPlans": "skills/writing-plans/SKILL.md",
    "subagentDev": "skills/subagent-driven-development/SKILL.md",
    "verification": "skills/verification-before-completion/SKILL.md",
    "mcpTelegram": "ACHIEVEMOR x AIMS/src/Runtime/Skills/mcp-telegram-bridge.skill.json",
    "mcpWeb3": "ACHIEVEMOR x AIMS/src/Runtime/Skills/mcp-web3-bridge.skill.json",
    "designTool": "skills/SME_DesignTool_Antigravity/SKILL.md",
    "autoResearch": "skills/SME_AutoResearch/SKILL.md"
  },
  "infrastructure": {
    "vps": {
      "ssh": "myclaw-vps",
      "ip": "31.97.133.29",
      "containers": {
        "nemoclaw": "openshell-cluster-nemoclaw",
        "simstudio": "sim-studio-9fks-simstudio-1",
        "openclaw": "openclaw-sop5-openclaw-1",
        "myclaw": "myclaw-myclaw-1",
        "traefik": "traefik-traefik-1"
      }
    }
  }
}
