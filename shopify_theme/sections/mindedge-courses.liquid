{% style %}
  .mindedge-page {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      color: #1A1D1E;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 20px;
      margin-top: 40px;
  }

  .mindedge-hero {
      background: #F7F9FA;
      text-align: center;
      padding: 80px 20px;
      border-radius: 16px;
      margin-bottom: 60px;
      position: relative;
      overflow: hidden;
      border: 1px solid #C1C4C7;
  }
  .mindedge-hero::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; height: 4px;
      background: linear-gradient(90deg, #206E8C, #03A6A6);
  }
  
  .mindedge-hero-badge {
      display: inline-block;
      background: rgba(3, 166, 166, 0.1);
      color: #206E8C;
      padding: 8px 16px;
      border-radius: 9999px;
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 24px;
      border: 1px solid rgba(3, 166, 166, 0.3);
  }

  .mindedge-hero h1 {
      font-family: 'Outfit', sans-serif;
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 800;
      margin: 0 0 24px 0;
      line-height: 1.1;
      letter-spacing: -1px;
      color: #1A1D1E;
  }
  .mindedge-hero h1 span {
      background: linear-gradient(135deg, #206E8C, #03A6A6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
  }
  .mindedge-hero p {
      font-size: 1.25rem;
      max-width: 800px;
      margin: 0 auto 40px auto;
      color: #565B5F;
      line-height: 1.6;
  }

  .mindedge-trust-bar {
      display: flex;
      justify-content: center;
      gap: 20px;
      flex-wrap: wrap;
      margin-top: 20px;
  }
  .trust-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.95rem;
      font-weight: 600;
      background: #FFFFFF;
      color: #1A1D1E;
      padding: 12px 24px;
      border-radius: 8px;
      border: 1px solid #C1C4C7;
  }
  .trust-item svg { width: 20px; height: 20px; fill: #206E8C; }

  /* CATEGORIES GRID */
  .mindedge-section-title {
      font-family: 'Outfit', sans-serif;
      text-align: center;
      font-size: 2.5rem;
      font-weight: 800;
      margin-bottom: 40px;
      letter-spacing: -0.5px;
      color: #1A1D1E;
  }

  .mindedge-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 24px;
      margin-bottom: 100px;
  }

  .mindedge-cat-card {
      background: #FFFFFF;
      border: 1px solid #C1C4C7;
      border-radius: 8px;
      padding: 32px 24px;
      text-align: center;
      transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-decoration: none !important;
      position: relative;
      overflow: hidden;
      color: #1A1D1E;
  }

  .mindedge-cat-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0; height: 4px;
      background: linear-gradient(90deg, #206E8C, #03A6A6);
      transform: scaleX(0);
      transition: transform 0.3s ease;
      transform-origin: left;
  }

  .mindedge-cat-card:hover {
      transform: translateY(-4px);
      border-color: #03A6A6;
      box-shadow: 0 10px 20px rgba(3, 166, 166, 0.1);
  }
  .mindedge-cat-card:hover::after {
      transform: scaleX(1);
  }

  .mindedge-cat-icon {
      width: 64px;
      height: 64px;
      border-radius: 12px;
      background: #F7F9FA;
      border: 1px solid #C1C4C7;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      margin-bottom: 20px;
      color: #03A6A6;
  }

  .mindedge-cat-title {
      font-family: 'Outfit', sans-serif;
      font-size: 1.5rem;
      font-weight: 800;
      margin: 0 0 12px 0;
      color: #1A1D1E;
  }
  .mindedge-cat-desc {
      font-size: 1rem;
      color: #565B5F;
      line-height: 1.5;
      margin: 0 0 24px 0;
      flex-grow: 1;
  }
  .mindedge-cat-btn {
      display: inline-block;
      padding: 10px 24px;
      background: #206E8C;
      color: #FFFFFF;
      font-weight: 600;
      border-radius: 4px;
      transition: background 0.2s, transform 0.2s;
  }
  .mindedge-cat-card:hover .mindedge-cat-btn {
      background: #03A6A6;
      transform: translateY(-2px);
      box-shadow: 0 4px 10px rgba(3, 166, 166, 0.2);
      color: #FFFFFF;
  }
  
  @media (max-width: 768px) {
      .mindedge-hero { padding: 60px 20px; }
      .mindedge-trust-bar { flex-direction: column; align-items: stretch; }
  }
{% endstyle %}

